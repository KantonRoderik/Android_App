<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/login_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        tools:context=".UI.profile.DailyGoalsSzerkesztes">

        <TextView
            android:id="@+id/edit_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/edit_daily_goals_title"
            android:textColor="@color/text_main"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- BMR Info Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/bmr_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#E3F2FD"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/edit_title">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/bmr_info_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="Your BMR: 1911 kcal"
                    android:textColor="#1976D2"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <Button
                    android:id="@+id/btn_use_bmr"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_use_this"
                    android:textColor="#1976D2"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Template Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/template_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/bmr_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_dietary_template"
                    android:textColor="@color/text_sub"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.7"/>

                <Spinner
                    android:id="@+id/template_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:background="@drawable/spinner_background"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Main Input Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/input_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/template_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Calorie Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_local_fire_department_24"
                        app:tint="#F44336" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dailyGoalsCalorie"
                        android:textColor="#F44336"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginStart="12dp"/>
                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                    <EditText
                        android:id="@+id/caloria"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edittext_background"
                        android:gravity="center"
                        android:inputType="number"
                        android:padding="8dp"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:selectAllOnFocus="true" />
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="@string/unit_kcal"
                        android:gravity="start"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#10000000" />

                <!-- Carbs Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_wheat_24"
                        app:tint="#FF9800" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dailyGoalsCarbs"
                        android:textColor="#FF9800"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginStart="12dp" />
                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                    <EditText
                        android:id="@+id/carbs"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edittext_background"
                        android:gravity="center"
                        android:inputType="number"
                        android:padding="8dp"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:selectAllOnFocus="true" />
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="@string/unit_g"
                        android:gravity="start"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#10000000" />

                <!-- Fat Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_bolt_24"
                        app:tint="#9C27B0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dailyGoalsFat"
                        android:textColor="#9C27B0"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginStart="12dp" />
                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                    <EditText
                        android:id="@+id/fat"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edittext_background"
                        android:gravity="center"
                        android:inputType="number"
                        android:padding="8dp"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:selectAllOnFocus="true" />
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="@string/unit_g"
                        android:gravity="start"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#10000000" />

                <!-- Protein Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_egg_24"
                        app:tint="#2196F3" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dailyGoalsProtein"
                        android:textColor="#2196F3"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginStart="12dp" />
                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                    <EditText
                        android:id="@+id/protein"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edittext_background"
                        android:gravity="center"
                        android:inputType="number"
                        android:padding="8dp"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:selectAllOnFocus="true" />
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="@string/unit_g"
                        android:gravity="start"
                        android:textColor="@color/text_sub"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#10000000" />

                <!-- Water Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_opacity_24"
                        app:tint="#03A9F4" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dailyGoalsWater"
                        android:textColor="#03A9F4"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginStart="12dp" />
                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                    <EditText
                        android:id="@+id/water"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edittext_background"
                        android:gravity="center"
                        android:inputType="number"
                        android:padding="8dp"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:selectAllOnFocus="true" />
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="@string/unit_ml"
                        android:gravity="start"
                        android:textColor="@color/text_sub"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/Mentes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:backgroundTint="#4CAF50"
            android:text="@string/btn_save_changes"
            android:padding="16dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/input_card" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/goals_footer_hint"
            android:textColor="@color/text_sub"
            android:textSize="12sp"
            android:alpha="0.6"
            app:layout_constraintTop_toBottomOf="@id/Mentes" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>